version: 1
recipe: service
preset: node

delivery:
  mode: staged
  pr:
    deployToStg: false

build:
  pnpm:
    nodeVersion: 20.19.2
    packageName: "@services/svc-messaging"
    packageDir: .
    steps:
      - type: lint
        name: Lint service sources
      - type: typecheck
        name: Typecheck service package
      - type: test
        name: Run unit tests
        command: test:unit
      - type: test
        name: Run integration tests
        command: test:integration
      - type: build
        name: Build service package

image:
  repository: registry.leultewolde.com/mereb/svc-messaging
  context: .
  dockerfile: Dockerfile
  tagStrategy: branch-sha
  verifyPull: true
  push:
    enabled: true
    when: '!pr'
    credentialsId: docker-registry-local
    registry: http://10.0.0.222:30400

deploy:
  order:
    - dev
    - dev_outbox
    - stg
    - stg_outbox
    - prd
    - prd_outbox

  defaults:
    chart: app-chart
    repo: https://charts.leultewolde.com
    repoCredentialId: helm-chart-creds
    wait: true
    atomic: true
    timeout: 10m

  generatedBaseDefaults:
    profile: apiService
    inputs:
      serviceName: svc-messaging
      containerPort: 4004
      routePrefix: /messages
      secretTemplates:
        DATABASE_URL: MESSAGING_DATABASE_URL
        SPLUNK_HEC_TOKEN: SPLUNK_HEC_TOKEN
      extraEnv:
        - name: OIDC_ISSUER
          fromPlatformIdentityConfigKey: OIDC_ISSUER

  dev:
    release: svc-messaging-dev
    namespace: apps-dev
    valuesFiles:
      - .ci/values-dev.yaml
    generatedBaseValues:
      inputs:
        configMapName: svc-messaging-dev-config
        secretName: svc-messaging-dev-secrets
        tlsSecretName: messages-dev-tls
    smoke:
      url: https://api-dev.mereb.app/messages/healthz
      retries: 3
      delay: 10
      timeout: 60s

  dev_outbox:
    extends: dev
    release: svc-messaging-dev-outbox
    namespace: apps-dev
    smoke: false
    generatedValues:
      profile: outboxWorker
      overlay:
        deploymentStrategy:
          type: RollingUpdate
          rollingUpdate:
            maxSurge: 0
            maxUnavailable: 1
    notes: "Dedicated outbox relay worker deployment"

  stg:
    release: svc-messaging-stg
    namespace: apps-stg
    valuesFiles:
      - .ci/values-stg.yaml
    generatedBaseValues:
      inputs:
        configMapName: svc-messaging-stg-config
        secretName: svc-messaging-stg-secrets
        tlsSecretName: messages-stg-tls
    smoke:
      url: https://api-stg.mereb.app/messages/healthz
      retries: 3
      delay: 10
      timeout: 60s

  stg_outbox:
    extends: stg
    release: svc-messaging-stg-outbox
    namespace: apps-stg
    smoke: false
    generatedValues:
      profile: outboxWorker
      overlay:
        deploymentStrategy:
          type: RollingUpdate
          rollingUpdate:
            maxSurge: 0
            maxUnavailable: 1
    notes: "Dedicated outbox relay worker deployment"

  prd:
    release: svc-messaging
    namespace: apps-prd
    valuesFiles:
      - .ci/values-prd.yaml
    generatedBaseValues:
      inputs:
        configMapName: svc-messaging-config
        secretName: svc-messaging-secrets
        tlsSecretName: messages-prd-tls
    smoke:
      url: https://api.mereb.app/messages/healthz
      retries: 3
      delay: 10
      timeout: 60s

  prd_outbox:
    extends: prd
    release: svc-messaging-outbox
    namespace: apps-prd
    smoke: false
    generatedValues:
      profile: outboxWorker
      overlay:
        deploymentStrategy:
          type: RollingUpdate
          rollingUpdate:
            maxSurge: 0
            maxUnavailable: 1
    notes: "Dedicated outbox relay worker deployment"

signing:
  enabled: false

release:
  autoTag:
    enabled: true
    when: branch=main & !pr
    prefix: v
    bump: patch
    remote: origin
    gitUser: Mereb CI
    gitEmail: ci@mereb.dev
    credentialId: github-credentials
    clean: false
    allowDirty: true
    skipIfTagged: true
  github:
    enabled: true
    when: tag=^v[0-9].*
    repo: leultewolde/mereb-svc-messaging
    stageName: GitHub Release
    credentialId: github-credentials
    generateReleaseNotes: true
